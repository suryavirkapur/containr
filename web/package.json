{
    "name": "znskr-web",
    "version": "0.1.0",
    "type": "module",
    "scripts": {
        "dev": "bunx vite",
        "build": "bunx vite build",
        "preview": "bunx vite preview",
        "generate:schema": "cd .. && cargo run --bin openapi --features openapi-only 2>/dev/null > web/src/api/openapi.json",
        "generate:client": "bunx openapi-typescript src/api/openapi.json -o src/api/schema.d.ts",
        "generate": "bun run generate:schema && bun run generate:client"
    },
    "dependencies": {
        "@solidjs/router": "^0.15.4",
        "openapi-fetch": "^0.15.0",
        "solid-js": "^1.9.10"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "^4.1.18",
        "@tailwindcss/vite": "^4.1.18",
        "autoprefixer": "^10.4.23",
        "postcss": "^8.5.6",
        "tailwindcss": "^4.1.18",
        "typescript": "^5.9.3",
        "vite": "^7.3.1",
        "vite-plugin-solid": "^2.11.10"
    }
}
